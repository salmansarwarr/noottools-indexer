# ── Server ────────────────────────────────────────────────────────────────────
INDEXER_PORT=3001

# ── Solana RPC ─────────────────────────────────────────────────────────────────
# Use a paid RPC (Helius, QuickNode, etc.) to avoid 429 rate limits
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# ── Bonding curve config ───────────────────────────────────────────────────────
PROGRAM_ID=TokenkegQfeZyiNwAJbNbGKPFXCWuBvf9Ss623VQ5DA
TOKEN_MINT=YourTokenMintAddressHere

# ── Indexer tuning ─────────────────────────────────────────────────────────────
POLL_INTERVAL_MS=5000          # How often to poll for new transactions
BATCH_SIZE=10                  # Transactions per getParsedTransactions call
MAX_SIGNATURES=1000            # Max signatures to fetch per poll cycle
INTER_BATCH_DELAY_MS=300       # Delay between batches to respect RPC rate limits

# ── Database ───────────────────────────────────────────────────────────────────
# DB_TYPE=sqlite               # "sqlite" (default) or "postgres"
DB_TYPE=sqlite
SQLITE_PATH=./data/indexer.db

# PostgreSQL (only used when DB_TYPE=postgres)
# PG_HOST=localhost
# PG_PORT=5432
# PG_DATABASE=bonding_indexer
# PG_USER=postgres
# PG_PASSWORD=secret

# ── Logging ────────────────────────────────────────────────────────────────────
LOG_LEVEL=info                 # error | warn | info | debug
